# ═══════════════════════════════════════════════════════════════
# Agent Comm Hub — 配置文件
# 复制为 .env 后按需修改，所有配置都有默认值
# ═══════════════════════════════════════════════════════════════

# Hub 服务
PORT=3100
LOG_LEVEL=info
CORS_ORIGINS=

# SQLite
DB_PATH=./comm_hub.db

# SSE
SSE_HEARTBEAT_INTERVAL=10000        # 心跳间隔（毫秒），默认 10s
SSE_REPLAY_WINDOW=3600              # 断线重放窗口（秒），默认 1h

# Rate Limit
RATE_LIMIT_WINDOW=1000              # 速率窗口（毫秒），默认 1s
RATE_LIMIT_MAX=10                   # 窗口内最大请求数

# Heartbeat Monitor
HEARTBEAT_ONLINE_THRESHOLD=90000    # 超时标记 offline（毫秒），默认 90s
HEARTBEAT_NOTIFY_THRESHOLD=300000   # 超时通知其他 Agent（毫秒），默认 5min
HEARTBEAT_CHECK_INTERVAL=30000      # 心跳检查间隔（毫秒），默认 30s

# Dedup
DEDUP_TTL=900                       # 去重缓存 TTL（秒），默认 15min
DEDUP_CLEANUP_INTERVAL=60000        # 去重清理间隔（毫秒），默认 1min

# Security
TOKEN_EXPIRE_DAYS=90                # API Token 有效期（天）
